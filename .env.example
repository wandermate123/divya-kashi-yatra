# ── Database (PostgreSQL) ─────────────────────────────────────────
# Vercel / production (Supabase): use Transaction pooler only — port 6543, e.g.
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connect_timeout=30
# Encode special chars in PASSWORD (@ → %40). No spaces or line breaks inside the value.
# Optional for serverless: add &connection_limit=1
#
# Migrations: run `npx prisma migrate deploy` from your machine using a URL Supabase gives
# for "Session" or "Direct" if the pooler cannot take locks — not required in Vercel env.

DATABASE_URL=

# ── Razorpay ────────────────────────────────────────────────────
# https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook signing secret (Dashboard → Webhooks), not the API Key Secret.
# https://dashboard.razorpay.com/app/webhooks

RAZORPAY_WEBHOOK_SECRET=
