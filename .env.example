# ── Database (PostgreSQL) ─────────────────────────────────────────
# Supabase:
#   DATABASE_URL → Transaction pooler :6543 … ?pgbouncer=true (app / Vercel runtime)
#   DIRECT_URL   → For local `prisma migrate`: db.<ref>.supabase.co :5432 often works.
#                  On Vercel builds, db.* often fails (P1001 / IPv6): use Session pooler
#                  :5432 on *.pooler.supabase.com with user postgres.<ref> instead.
# `npm run build` = next build only (no migrate on Vercel). Before deploy when you change
#   schema: run `npm run db:migrate` locally against prod, or set Vercel Build Command to
#   `npm run build:with-migrate` after DIRECT_URL is a pooler URL Vercel can reach.
# Local / Neon: set DIRECT_URL = same as DATABASE_URL if you use one URL.

DATABASE_URL=
DIRECT_URL=

# ── Razorpay ────────────────────────────────────────────────────
# https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook signing secret (Dashboard → Webhooks), not the API Key Secret.
# https://dashboard.razorpay.com/app/webhooks

RAZORPAY_WEBHOOK_SECRET=
