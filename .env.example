# ── Database (PostgreSQL) ─────────────────────────────────────────
# Vercel: Project → Settings → Environment Variables → add DATABASE_URL for Production
#   (and Preview if you use it). Redeploy after saving — env changes don’t apply to old deploys.
#
# Supabase: Dashboard → Connect → Method: Transaction pooler (port 6543). Do not use Direct (5432) for Vercel.
# URI is often: postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres
#   or: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# The app adds pgbouncer/ssl/connect_timeout/connection_limit if missing (transaction pooler only).
#
# Example with explicit params:
#   postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&sslmode=require&connect_timeout=30&connection_limit=1
#
# URL-encode special characters in PASSWORD (e.g. @ → %40, # → %23). No spaces or line breaks.
#
# Migrations: run `npx prisma migrate deploy` locally using Supabase “Session” or “Direct” (5432)
# if the pooler cannot take locks — that URL is not what Vercel should use at runtime.

DATABASE_URL=

# ── Razorpay ────────────────────────────────────────────────────
# https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook signing secret (Dashboard → Webhooks), not the API Key Secret.
# https://dashboard.razorpay.com/app/webhooks

RAZORPAY_WEBHOOK_SECRET=
