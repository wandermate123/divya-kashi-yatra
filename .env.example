# ── Database (PostgreSQL) ─────────────────────────────────────────
# Supabase:
#   DATABASE_URL → Transaction pooler :6543 … ?pgbouncer=true (app runtime)
#   DIRECT_URL   → Direct connection host db.<ref>.supabase.co :5432 (migrations).
#     If migrate still times out (P1002) on pooler :5432, you must use this direct URI.
#     Username is usually "postgres" (not postgres.<ref>) for the direct host.
# Local / Neon: set DIRECT_URL = same as DATABASE_URL.

DATABASE_URL=
DIRECT_URL=

# ── Razorpay ────────────────────────────────────────────────────
# https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook signing secret (Dashboard → Webhooks), not the API Key Secret.
# https://dashboard.razorpay.com/app/webhooks

RAZORPAY_WEBHOOK_SECRET=
