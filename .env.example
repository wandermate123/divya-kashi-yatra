# ── Database (PostgreSQL) ─────────────────────────────────────────
# Vercel: Settings → Environment Variables → add BOTH vars below for Production (and Preview if needed).
#   Redeploy after saving. The app uses the Transaction pooler via Prisma + node-postgres (see src/lib/prisma.ts).
#
# --- DATABASE_URL (runtime): Transaction pooler, port 6543 ---
# Supabase → Connect → Transaction. Copy the URI exactly; username must match what Supabase shows
# (either `postgres` or `postgres.PROJECT_REF` depending on host).
# Common shapes:
#   postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# The app appends ?pgbouncer=true&sslmode=require&connect_timeout=30&connection_limit=1 if missing.
# URL-encode special characters in PASSWORD (@ → %40, # → %23). One line, no spaces.
#
# --- DIRECT_URL (Prisma CLI / migrations only, but keep in Vercel so builds stay valid): ---
# Connect → Session mode (port 5432) OR Direct connection — never use :6543 here.
# Example: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# For local-only work you can omit on Vercel only if you never run prisma migrate in CI; safest is to set both.

DATABASE_URL=
DIRECT_URL=

# TLS: Supabase pooler defaults to encrypted connections without strict CA verification
# so Vercel/serverless avoids P1011. For strict certificate verification set:
#   DATABASE_SSL_REJECT_UNAUTHORIZED=true


# ── Razorpay ────────────────────────────────────────────────────
# https://dashboard.razorpay.com/app/keys
#
# If a UPI QR shows the wrong payee (e.g. an old business name), that comes from your
# Razorpay account/KYC/legal name — update in Dashboard → Settings → Account & setup
# (business details) or ask Razorpay support; checkout `name` in code only affects the modal.

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook signing secret (Dashboard → Webhooks), not the API Key Secret.
# https://dashboard.razorpay.com/app/webhooks

RAZORPAY_WEBHOOK_SECRET=
