# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/divya_kashi_yatra?schema=public"

# Razorpay — API keys: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret (separate from Key Secret) — https://dashboard.razorpay.com/app/webhooks
# 1. Add webhook URL: https://YOUR_DOMAIN/api/payments/webhook (use your real origin; must be HTTPS in production).
# 2. Enable at least: payment.captured, payment.authorized, and optionally order.paid.
# 3. After saving, copy the webhook "Secret" shown for that URL into this variable.
# Signature is HMAC-SHA256 of the raw body; this route uses request.text() before JSON.parse.
RAZORPAY_WEBHOOK_SECRET=paste_webhook_secret_from_dashboard
